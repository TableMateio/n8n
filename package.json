{
  "name": "n8n-nodes-ventriloquist",
  "version": "0.1.0",
  "description": "N8N node for browser automation via Bright Data's Scraping Browser",
  "keywords": [
    "n8n-community-node-package",
    "n8n-node-package",
    "puppeteer",
    "browser-automation",
    "web-scraping"
  ],
  "license": "MIT",
  "homepage": "https://github.com/yourusername/n8n-nodes-ventriloquist",
  "author": {
    "name": "Your Name",
    "email": "your.email@example.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/n8n-nodes-ventriloquist.git"
  },
  "main": "index.js",
  "scripts": {
    "start": "node scripts/run.js",
    "build": "tsc && cp README.md dist/",
    "dev": "tsc --watch",
    "format": "prettier nodes credentials package.json --write",
    "lint": "eslint nodes credentials package.json",
    "lintfix": "eslint nodes credentials package.json --fix",
    "prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json"
  },
  "files": [
    "dist"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/BrightDataApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Ventriloquist/Ventriloquist.node.js"
    ]
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^18.16.0",
    "@typescript-eslint/eslint-plugin": "^6.7.0",
    "@typescript-eslint/parser": "^6.7.0",
    "eslint": "^8.49.0",
    "eslint-plugin-n8n-nodes-base": "^1.16.0",
    "prettier": "^3.0.3",
    "typescript": "~5.2.2"
  },
  "dependencies": {
    "n8n-core": "^1.8.0",
    "n8n-workflow": "^1.8.0",
    "puppeteer-core": "^22.0.0"
  }
}
